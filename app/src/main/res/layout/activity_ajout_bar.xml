<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:padding="20dp">

    <EditText
        android:id="@+id/nom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nom du Bar"
        android:textColorHint="#888888"
        android:textColor="@android:color/black"
        android:layout_marginTop="10dp" />

    <EditText
        android:id="@+id/adresse_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Adresse"
        android:textColorHint="#888888"
        android:textColor="@android:color/black"
        android:layout_marginTop="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Note :"
        android:textColor="@android:color/black"
        android:layout_marginTop="30dp"
        android:textStyle="bold" />

    <RatingBar
        android:id="@+id/rating_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:numStars="5"
        android:progressTint="@color/blue_logo"
        android:stepSize="1" />

    <EditText
        android:id="@+id/comm_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Commentaire..."
        android:textColorHint="#888888"
        android:textColor="@android:color/black"
        android:layout_marginTop="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ambiances (3 max) :"
        android:textColor="@android:color/black"
        android:layout_marginTop="20dp"
        android:textStyle="bold" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_ambiance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:chipSpacingVertical="8dp"
        app:chipSpacingHorizontal="8dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_chill"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chill" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_lgbt"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LGBTQIA+" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_shatta"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shatta" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_house"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="House" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_commercial"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Commercial" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_techno"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Techno" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_hard"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hard" />

    </com.google.android.material.chip.ChipGroup>


    <Button
        android:id="@+id/save_bar_btn"
        android:textAllCaps="false"
        app:cornerRadius="28dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:backgroundTint="@color/blue_logo"
        android:text="ENREGISTRER MON BAR"
        android:textColor="@android:color/white" />

    <Button
        android:id="@+id/btn_add_photo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ajouter une photo à l'album" />

</LinearLayout>